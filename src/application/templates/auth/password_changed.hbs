{{#> layouts/base }}
    <p class="eyebrow">Account security</p>
    <h1 class="title">Your password has been changed.</h1>
    <p class="text">
        Hello, {{name}}. This message confirms that your account password was updated successfully.
    </p>

    <div class="panel">
        <div class="panel-inner">
            <table role="presentation" width="100%">
                <tr class="row">
                    <td class="label-cell">Account holder</td>
                    <td class="value-cell">{{name}}</td>
                </tr>
                <tr class="row">
                    <td class="label-cell">Action</td>
                    <td class="value-cell">Password changed successfully</td>
                </tr>
            </table>
        </div>
    </div>

    <p class="note">
        If you do not recognize this change, update your password immediately and contact support.
    </p>
{{/layouts/base}}
