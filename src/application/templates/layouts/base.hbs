<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArchGTI</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            color: #111827;
            font-family: "Segoe UI", Arial, Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
            border-spacing: 0;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            display: block;
            line-height: 100%;
            max-width: 100%;
        }

        a {
            color: #2563eb;
        }

        .shell {
            width: 100%;
            background-color: #f3f4f6;
            padding: 24px 12px;
        }

        .card {
            width: 100%;
            max-width: 640px;
            background-color: #ffffff;
            border: 1px solid #d7dce5;
            border-radius: 14px;
            overflow: hidden;
        }

        .header {
            background-color: #040404;
            color: #ffffff;
            padding: 32px 36px;
        }

        .brand {
            margin: 0;
            color: #ffffff;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: 0.28em;
            text-transform: uppercase;
        }

        .brand-subtitle {
            margin: 12px 0 0;
            color: #a5b1c2;
            font-size: 13px;
            line-height: 1.6;
            letter-spacing: 0.08em;
        }

        .content {
            padding: 34px 36px 30px;
            background-color: #ffffff;
        }

        .eyebrow {
            margin: 0 0 12px;
            color: #6b7280;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.16em;
            text-transform: uppercase;
        }

        .title {
            margin: 0 0 14px;
            color: #111827;
            font-size: 28px;
            line-height: 1.2;
            font-weight: 700;
        }

        .text {
            margin: 0 0 16px;
            color: #4b5563;
            font-size: 15px;
            line-height: 1.75;
        }

        .panel {
            margin-top: 24px;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            background-color: #fafafa;
        }

        .panel-inner {
            padding: 8px 24px;
        }

        .row {
            width: 100%;
            border-bottom: 1px solid #e5e7eb;
        }

        .row:last-child {
            border-bottom: none;
        }

        .label-cell {
            width: 132px;
            padding: 16px 0;
            color: #6b7280;
            font-size: 14px;
            line-height: 1.6;
            vertical-align: top;
        }

        .value-cell {
            padding: 16px 0;
            color: #111827;
            font-size: 15px;
            line-height: 1.7;
            vertical-align: top;
            word-break: break-word;
        }

        .button-wrap {
            padding-top: 8px;
        }

        .button {
            display: inline-block;
            padding: 14px 22px;
            background-color: #111827;
            border-radius: 10px;
            color: #ffffff !important;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
        }

        .link {
            color: #2563eb;
            text-decoration: none;
            word-break: break-all;
        }

        .note {
            margin: 20px 0 0;
            color: #6b7280;
            font-size: 13px;
            line-height: 1.7;
        }

        .footer {
            background-color: #f3f4f6;
            border-top: 1px solid #e5e7eb;
            padding: 20px 24px;
            text-align: center;
            color: #6b7280;
            font-size: 12px;
            line-height: 1.7;
        }

        @media only screen and (max-width: 620px) {
            .shell {
                padding: 12px !important;
            }

            .header,
            .content,
            .footer {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .title {
                font-size: 24px !important;
            }

            .label-cell,
            .value-cell {
                display: block !important;
                width: 100% !important;
                padding: 6px 0 !important;
            }

            .row {
                display: block !important;
                padding: 8px 0 !important;
            }

            .button {
                display: block !important;
                width: 100% !important;
                box-sizing: border-box;
                text-align: center !important;
            }
        }
    </style>
</head>

<body>
    <table role="presentation" width="100%" class="shell">
        <tr>
            <td align="center">
                <table role="presentation" width="100%" class="card" style="max-width: 640px;">
                    {{> partials/header}}
                    <tr>
                        <td class="content" style="padding: 34px 36px 30px; background-color: #ffffff;">
                            {{> @partial-block}}
                        </td>
                    </tr>
                    {{> partials/footer}}
                </table>
            </td>
        </tr>
    </table>
</body>

</html>
