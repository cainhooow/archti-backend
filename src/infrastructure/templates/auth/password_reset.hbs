{{#> layouts/base }}
    <p class="eyebrow">Password reset</p>
    <h1 class="title">Set a new password.</h1>
    <p class="text">
        Hello, {{name}}. To continue resetting your account password, use the button below.
    </p>

    <div class="button-wrap">
        <a href="{{link}}" class="button">Reset password</a>
    </div>

    <p class="text" style="margin-top: 22px;">
        If the button does not work, copy and paste this link into your browser:
    </p>
    <p class="text">
        <a href="{{link}}" class="link">{{link}}</a>
    </p>

    <div class="panel">
        <div class="panel-inner">
            <table role="presentation" width="100%">
                <tr class="row">
                    <td class="label-cell">Account holder</td>
                    <td class="value-cell">{{name}}</td>
                </tr>
                <tr class="row">
                    <td class="label-cell">Action</td>
                    <td class="value-cell">Create a new password</td>
                </tr>
            </table>
        </div>
    </div>

    <p class="note">
        If you did not request this reset, ignore this message. No changes will be made without your confirmation.
    </p>
{{/layouts/base}}
